DB_HOST=db
DB_PORT=5432
DB_NAME=sikassarangan
DB_USER=sikassarangan_user
DB_PASSWORD=change-this-to-a-strong-random-password

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-this-to-a-strong-random-password

API_KEY=change-this-api-key
API_PORT=443

# Fallback user id untuk createdById selama sistem login per-user (Firebase) belum aktif.
# Diisi otomatis oleh middleware attachCurrentUser kalau request tidak membawa header x-user-id.
# Nilai 1 = user default "system@sikassarangan.local" yang dibuat oleh migration/seed.
DEFAULT_USER_ID=1

DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=public

# Firebase Admin SDK — service account JSON yang di-encode base64 (satu baris).
# Wajib di-set agar verifikasi token & push notification aktif. JANGAN commit nilainya.
# Cara generate ada di README/penjelasan. Contoh (Linux/Mac):
#   base64 -w0 serviceAccount.json
FIREBASE_SERVICE_ACCOUNT_BASE64=
